# ===========================
# SSH Connection Settings
# ===========================

# IP-адрес или hostname удалённого сервера
SSH_HOST=192.168.1.100

# SSH-порт (по умолчанию 22)
SSH_PORT=22

# Имя пользователя для SSH-подключения
SSH_USER=root

# Метод авторизации: "key" или "password"
SSH_AUTH_METHOD=key

# Путь к приватному SSH-ключу (используется при SSH_AUTH_METHOD=key)
SSH_KEY_PATH=/root/.ssh/id_rsa

# Пароль SSH (используется при SSH_AUTH_METHOD=password)
SSH_PASSWORD=

# Пароль для SSH-ключа (если ключ защищён паролем)
SSH_KEY_PASSPHRASE=

# ===========================
# StorCLI Settings
# ===========================

# Путь до утилиты storcli на удалённом сервере
STORCLI_PATH=/opt/lsi/storcli/storcli

# Контроллер и команда (по умолчанию /c0 show all)
STORCLI_CONTROLLER=/c0

# ===========================
# Application Settings
# ===========================

# Хост и порт для запуска FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000

# ===========================
# Authentication
# ===========================

# Логин и пароль для входа в веб-интерфейс
AUTH_USERNAME=admin
AUTH_PASSWORD=admin

# Секретный ключ для подписи сессий (сгенерируйте свой, например: openssl rand -hex 32)
# Оставьте пустым для автогенерации каждый запуск (тогда сессии будут сбрасываться при перезапуске сервера)
SECRET_KEY=

# Время жизни сессии в секундах (по умолчанию 24 часа = 86400)
SESSION_TTL=86400

# ===========================
# Debug & Core
# ===========================

# Таймаут SSH-подключения в секундах
SSH_TIMEOUT=10

# Режим отладки (true — использовать Example.json вместо SSH)
DEBUG_MODE=false
